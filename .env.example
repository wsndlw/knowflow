NODE_ENV=development

# PostgreSQL + pgvector
POSTGRES_DB=knowflow
POSTGRES_USER=knowflow
POSTGRES_PASSWORD=knowflow_password
POSTGRES_PORT=5432
DATABASE_URL=postgres://knowflow:knowflow_password@localhost:5432/knowflow

# Redis + BullMQ
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Local services
API_HOST=0.0.0.0
API_PORT=4000
API_PUBLIC_URL=http://localhost:4000
WEB_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Seed bootstrap account
SEED_ADMIN_USER=admin
SEED_ADMIN_PASSWORD=ChangeMe_123456
SEED_ADMIN_NAME=System Administrator

# Session and encryption secrets. Replace in real deployments.
SESSION_SECRET=replace-with-a-long-random-session-secret
MODEL_API_KEY_ENCRYPTION_KEY=replace-with-32-byte-base64-key

# Aliyun Bailian placeholders for P0 default provider seed.
ALIYUN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ALIYUN_API_KEY=

# Local file storage for uploaded documents and conversation attachments.
LOCAL_STORAGE_ROOT=./storage
